<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Painel - Ateliê da Transformação</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* =============================================================================
           ATELIÊ DA TRANSFORMAÇÃO - DESIGN SYSTEM (VARIÁVEIS GLOBAIS)
           ============================================================================= */
        :root {
            --artisan-clay: #b85d43; /* Terracota / Argila */
            --artisan-wood: #3d2b1f; /* Castanho Madeira Nobre */
            --artisan-gold: #cf9e53; /* Latão / Ouro Envelhecido */
            --artisan-sand: #f8f9fa; /* Background Global Light */
            --text-main: #2a2421; /* Antracite Orgânico */
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--artisan-sand); 
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }
        
        /* Sidebar Desktop Totalmente Branca */
        .sidebar { 
            background-color: #ffffff; 
            min-height: 100vh; 
            color: var(--text-main); 
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            padding: 20px;
            border-right: 1px solid #e5e7eb;
        }
        
        .sidebar .nav-link { 
            color: #666; 
            border-radius: 8px; 
            margin-bottom: 6px; 
            padding: 12px 15px; 
            text-decoration: none; 
            display: flex;
            align-items: center;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        
        .sidebar .nav-link:hover { 
            background-color: #f3f4f6; 
            color: var(--text-main); 
        }

        /* Destaque do link ativo combinado com a identidade visual */
        .sidebar .nav-link.active {
            background-color: rgba(184, 93, 67, 0.1);
            color: var(--artisan-clay);
            font-weight: 600;
        }
        
        /* Ajuste do conteúdo principal */
        .main-content {
            margin-left: 16.666667%; /* Equivalente a col-md-2 */
        }

        /* Inputs de Formulários Administrativos e Autenticação */
        .form-floating > .form-control:focus, .form-control:focus, .form-select:focus {
            border-color: var(--artisan-clay) !important;
            box-shadow: 0 0 0 0.25rem rgba(184, 93, 67, 0.25) !important;
        }
        .form-control.form-active, .form-select.form-active {
            border-color: var(--artisan-gold) !important;
            box-shadow: 0 4px 12px rgba(207, 158, 83, 0.2) !important;
            transition: all 0.2s ease-in-out;
        }

        /* 🛠️ Ajuste de Responsividade para Celulares e Tablets */
        @@media (max-width: 767.98px) {
            .sidebar {
                position: static !important;
                min-height: auto !important;
                width: 100% !important;
                box-shadow: none;
            }

            .main-content {
                margin-left: 0 !important;
                padding-top: 20px;
            }
        }
    </style>
</head>
<body>

    <header class="navbar navbar-light sticky-top bg-white p-3 shadow-sm border-bottom d-md-none">
        <span class="navbar-brand mb-0 h1 fs-6 fw-bold text-dark">
            <i class="bi bi-shield-lock-fill text-warning me-2"></i>Ateliê Admin
        </span>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebarMobile" aria-controls="adminSidebarMobile" aria-label="Abrir Menu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </header>

    <div class="container-fluid">
        <div class="row">
            
            <nav id="adminSidebar" class="col-md-3 col-lg-2 d-none d-md-flex sidebar flex-column justify-content-between">
                <div>
                    <div class="d-flex align-items-center mb-4 px-2 pt-2">
                        <span class="fs-5 fw-bold text-dark">
                            <i class="bi bi-shield-lock-fill text-warning me-2"></i>Ateliê Admin
                        </span>
                    </div>
                    <hr class="text-muted">
                    
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index"><i class="bi bi-grid-1x2-fill me-2"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="CreateProduct"><i class="bi bi-plus-circle-fill me-2"></i>Nova Peça</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="CreateCategory"><i class="bi bi-folder-plus me-2"></i>Nova Categoria</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-info" asp-controller="Home" asp-action="Index" target="_blank"><i class="bi bi-eye-fill me-2"></i>Ver Loja</a>
                        </li>
                    </ul>
                </div>

                <div class="mb-3">
                    <hr class="text-muted mb-3">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold rounded-pill text-start px-3 py-2 d-flex align-items-center">
                            <i class="bi bi-box-arrow-left me-2"></i>Sair
                        </button>
                    </form>
                </div>
            </nav>

            <div class="offcanvas offcanvas-start bg-white text-dark d-md-none" tabindex="-1" id="adminSidebarMobile" aria-labelledby="adminSidebarMobileLabel">
                <div class="offcanvas-header border-bottom">
                    <h5 class="offcanvas-title fw-bold" id="adminSidebarMobileLabel">
                        <i class="bi bi-shield-lock-fill text-warning me-2"></i>Ateliê Admin
                    </h5>
                    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body d-flex flex-column justify-content-between" style="background-color: #ffffff; padding: 20px;">
                    <div>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index"><i class="bi bi-grid-1x2-fill me-2"></i>Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="CreateProduct"><i class="bi bi-plus-circle-fill me-2"></i>Nova Peça</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="CreateCategory"><i class="bi bi-folder-plus me-2"></i>Nova Categoria</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-info" asp-controller="Home" asp-action="Index" target="_blank"><i class="bi bi-eye-fill me-2"></i>Ver Loja</a>
                            </li>
                        </ul>
                    </div>
                    <div class="mb-3">
                        <hr class="text-muted mb-3">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold rounded-pill text-start px-3 py-2 d-flex align-items-center">
                                <i class="bi bi-box-arrow-left me-2"></i>Sair
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 main-content">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Marcar link ativo na navegação baseado na URL atual
            const currentUrl = window.location.pathname.toLowerCase();
            const navLinks = document.querySelectorAll('.nav-link');

            navLinks.forEach(link => {
                const href = link.getAttribute('href');
                if (href && currentUrl.includes(href.toLowerCase()) && href !== "/") {
                    link.classList.add('active');
                }
            });

            // 2. Feedback visual nos inputs de formulário (.form-active)
            const inputs = document.querySelectorAll(".form-control, .form-select");
            inputs.forEach(input => {
                input.addEventListener("focus", () => input.classList.add("form-active"));
                input.addEventListener("blur", () => input.classList.remove("form-active"));
            });

            // 3. Gerenciamento interativo inteligente do Hamburguer/Offcanvas
            const toggler = document.querySelector('.navbar-toggler[data-bs-target="#adminSidebarMobile"]');
            const offcanvasEl = document.getElementById('adminSidebarMobile');

            if (toggler && offcanvasEl) {
                toggler.addEventListener('click', function () {
                    if (window.bootstrap && typeof window.bootstrap.Offcanvas === 'function') {
                        const instance = bootstrap.Offcanvas.getOrCreateInstance(offcanvasEl);
                        instance.toggle();
                    } else {
                        offcanvasEl.classList.toggle('show');
                    }
                });
            }

            // --- Adicionado: garantir que o botão 'X' feche o offcanvas sem remover nada ---
            if (offcanvasEl) {
                const closeBtn = offcanvasEl.querySelector('[data-bs-dismiss="offcanvas"]');
                if (closeBtn) {
                    closeBtn.addEventListener('click', function (e) {
                        // Usa API do Bootstrap se disponível, senão fallback que remove a classe 'show'
                        if (window.bootstrap && typeof window.bootstrap.Offcanvas === 'function') {
                            const instance = bootstrap.Offcanvas.getOrCreateInstance(offcanvasEl);
                            instance.hide();
                        } else {
                            offcanvasEl.classList.remove('show');
                        }
                    });
                }
            }
            // --- fim da adição ---
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>