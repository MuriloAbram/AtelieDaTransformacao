<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ateliê da Transformação</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bundle.min.js" defer></script>
</head>
<body class="d-flex flex-column min-vh-100" style="--artisan-gold: #dfb76c; --artisan-clay: #b85a3a; --artisan-wood: #1a1512;">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-artisan-dark navbar-artisan py-3 shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center fw-bold serif-title fs-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tree-fill text-gold me-2 fs-3"></i>Ateliê da <span class="text-gold ms-2">Transformação</span>
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-5">
                        <li class="nav-item">
                            <a class="nav-link nav-link-artisan fw-medium px-3" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-collection-fill me-1 small text-gold"></i> Galeria de Obras
                            </a>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-outline-artisan btn-sm px-4 py-2 rounded-pill fw-semibold" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-sliders me-1"></i> Painel do Artesão
                                </a>
                            }

                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 d-inline">
                                <button type="submit" class="btn btn-link text-white-50 text-decoration-none small p-2 opacity-75">
                                    <i class="bi bi-box-arrow-right me-1"></i> Sair
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-link text-white-50 text-decoration-none small px-3 fw-medium opacity-75" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                            </a>
                            <a class="btn btn-outline-artisan btn-sm px-4 py-2 rounded-pill fw-semibold" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Criar Conta
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index")
    {
        <div id="artisanHeroCarousel" class="carousel slide carousel-fade shadow-sm mb-5" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#artisanHeroCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#artisanHeroCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#artisanHeroCarousel" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner" style="max-height: 550px; background-color: var(--artisan-wood);">
                
                <div class="carousel-item active" data-bs-interval="6000">
                    <div class="position-relative w-100" style="height: 550px; background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.75)), url('https://images.unsplash.com/photo-1610701596007-11502861afab?q=80&w=1600') center/cover no-repeat;">
                        <div class="carousel-caption h-100 d-flex flex-column justify-content-center align-items-start text-start px-md-5" style="max-width: 750px; bottom: 0;">
                            <span class="badge text-dark text-uppercase mb-3 px-3 py-2 rounded-pill fw-bold" style="background-color: var(--artisan-gold, #dfb76c) !important;">Design Exclusivo</span>
                            <h1 class="display-4 fw-bold text-white serif-title mb-3">Mobiliário Orgânico & Resina Fluida</h1>
                            <p class="lead text-white-50 mb-4">Peças únicas esculpidas a partir de troncos de descarte e resina de alta resistência. Arte viva para transformar o seu espaço com requinte.</p>
                            <a href="#galeria-ancora" class="btn btn-outline-light border-2 px-4 py-2 rounded-pill fw-semibold">Explorar Coleção</a>
                        </div>
                    </div>
                </div>
                
                <div class="carousel-item" data-bs-interval="6000">
                    <div class="position-relative w-100" style="height: 550px; background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.75)), url('https://images.unsplash.com/photo-1455792244726-6d13a5a5130f?q=80&w=1600') center/cover no-repeat;">
                        <div class="carousel-caption h-100 d-flex flex-column justify-content-center align-items-start text-start px-md-5" style="max-width: 750px; bottom: 0;">
                            <span class="badge text-white text-uppercase mb-3 px-3 py-2 rounded-pill fw-bold" style="background-color: var(--artisan-clay, #b85a3a) !important;">Sustentabilidade</span>
                            <h1 class="display-4 fw-bold text-white serif-title mb-3">Autenticidade Esculpida à Mão</h1>
                            <p class="lead text-white-50 mb-4">Respeitamos a história e a curvatura original da madeira rústica, garantindo que cada peça gourmet, mesa ou bancada traga uma identidade irreplicável.</p>
                            <a href="#galeria-ancora" class="btn btn-outline-light border-2 px-4 py-2 rounded-pill fw-semibold">Ver Peças Prontas</a>
                        </div>
                    </div>
                </div>
                
                <div class="carousel-item" data-bs-interval="6000">
                    <div class="position-relative w-100" style="height: 550px; background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.75)), url('https://images.unsplash.com/photo-1600585154526-990dced4db0d?q=80&w=1600') center/cover no-repeat;">
                        <div class="carousel-caption h-100 d-flex flex-column justify-content-center align-items-start text-start px-md-5" style="max-width: 750px; bottom: 0;">
                            <span class="badge text-uppercase mb-3 px-3 py-2 rounded-pill fw-bold" style="background-color: var(--artisan-gold, #dfb76c) !important; color: var(--artisan-wood, #1a1512)">Projetos sob Medida</span>
                            <h1 class="display-4 fw-bold text-white serif-title mb-3">Direto para o seu WhatsApp</h1>
                            <p class="lead text-white-50 mb-4">Escolha o modelo ideal em nossa vitrine digital e entre em contato direto com o mestre artesão para alinhar dimensões e detalhes de entrega.</p>
                            <a href="https://wa.me/seu_numero" target="_blank" class="btn btn-success px-4 py-2 rounded-pill fw-semibold border-0 shadow" style="background-color: #25d366;"><i class="bi bi-whatsapp me-2"></i>Encomendar Agora</a>
                        </div>
                    </div>
                </div>

            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#artisanHeroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Anterior</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#artisanHeroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Seguinte</span>
            </button>
        </div>
        <div id="galeria-ancora"></div>
    }

    <main role="main" class="flex-grow-1 container my-2">
        @RenderBody()
    </main>

    <section class="py-5 bg-white border-top border-bottom border-light shadow-sm">
        <div class="container">
            <div class="row g-4 text-center">
                <div class="col-md-4">
                    <div class="p-3">
                        <i class="bi bi-shield-check text-gold fs-1 mb-3 d-block"></i>
                        <h5 class="fw-bold text-dark serif-title">Garantia Origem</h5>
                        <p class="text-muted small mb-0">Madeiras nobres certificadas, rastreáveis e extraídas em total conformidade socioambient.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3">
                        <i class="bi bi-droplet-half text-gold fs-1 mb-3 d-block"></i>
                        <h5 class="fw-bold text-dark serif-title">Resina Premium</h5>
                        <p class="text-muted small mb-0">Proteção UV total que evita o amarelecimento, oferecendo acabamento vitrificado cristalino.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3">
                        <i class="bi bi-whatsapp text-gold fs-1 mb-3 d-block"></i>
                        <h5 class="fw-bold text-dark serif-title">Atendimento Direto</h5>
                        <p class="text-muted small mb-0">Sem intermediários. Negocie diretamente com o mestre artesão responsável pela sua obra.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-artisan-dark text-white-50 py-5">
        <div class="container text-center">
            <h4 class="serif-title text-white mb-2">Ateliê da Transformação</h4>
            <p class="small opacity-50 mb-4 mx-auto" style="max-width: 500px;">
                Mobiliário Orgânico de Luxo, Arte Rústica Funcional e Design Customizado sob Medida.
            </p>
            <div class="border-top border-secondary border-opacity-10 pt-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <small class="small opacity-75">&copy; @System.DateTime.Now.Year T1B-3 Digital Studio. Todos os direitos reservados. | Desenvolvido com 💙 pela T1B-3.</small>
                <div class="d-flex gap-3 small">
                    <a href="#" class="text-white-50 text-decoration-none opacity-75">Termos de Uso</a>
                    <span class="text-secondary opacity-25">|</span>
                    <a href="#" class="text-white-50 text-decoration-none opacity-75">Política de Privacidade</a>
                </div>
            </div>
        </div>
    </footer>

    <a href="https://wa.me/seu_numero" class="whatsapp-float" target="_blank" title="Falar Conosco no WhatsApp">
        <i class="bi bi-whatsapp"></i>
    </a>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>