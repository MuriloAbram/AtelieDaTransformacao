<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ateliê da Transformação</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-artisan-dark py-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center fw-bold serif-title fs-3" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tree-fill text-gold me-2 fs-4"></i>Ateliê da <span class="text-gold ms-1">Transformação</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link text-white-50 fw-medium" asp-controller="Home" asp-action="Index">Coleção de Obras</a>
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @* O botão só será exibido se o utilizador estiver autenticado E tiver o papel de Admin *@
                            if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-outline-artisan btn-sm px-3 rounded-pill" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-cpu me-1"></i> Painel de Gestão
                                </a>
                            }

                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="btn btn-link text-white-50 text-decoration-none small p-2">Sair</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-link text-white-50 text-decoration-none small px-3 fw-medium" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                            </a>
                            <a class="btn btn-outline-artisan btn-sm px-3 rounded-pill" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Criar Conta
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-artisan-dark text-white-50 py-5 mt-5">
        <div class="container text-center">
            <h5 class="serif-title text-white mb-2">Ateliê da Transformação</h5>
            <p class="small opacity-50 mb-4">Mobiliário Orgânico, Arte Rústica e Design Customizado sob Medida</p>
            <div class="border-top border-secondary border-opacity-25 pt-3">
                <small>&copy; @System.DateTime.Now.Year — Autenticidade esculpida à mão.</small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)</body>
</html>