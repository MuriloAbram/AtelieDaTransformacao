@model AtelieDaTransformacao.Application.DTOs.ProductDto

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row g-5">
        <div class="col-md-6">
            <img src="@(string.IsNullOrEmpty(Model.Image) ? "/images/placeholder.jpg" : Model.Image)"
                 class="img-fluid rounded shadow-sm w-100 object-fit-cover" style="max-height: 500px;" alt="@Model.Title">
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-center">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dark">Catálogo</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.CategoryName</li>
                </ol>
            </nav>

            <h1 class="display-5 fw-bold mb-3">@Model.Title</h1>
            <h2 class="text-success mb-4 fw-semibold">@Model.Price.ToString("C")</h2>
            
            <hr class="my-4">
            
            <h5 class="fw-bold">Descrição da Peça</h5>
            <p class="lead text-muted">@Model.Description</p>

            <div class="mt-4 p-4 bg-light rounded border">
                <h6 class="fw-bold mb-2"><i class="bi bi-info-circle-fill text-primary"></i> Como funciona a compra?</h6>
                <p class="small text-muted mb-3">Este ateliê trabalha com peças exclusivas e sob medida. Clique abaixo para alinhar os detalhes da entrega e pagamento diretamente com o artesão.</p>
                
                @if (Model.IsAvailable)
                {
                    <a href="@Model.WhatsAppLink" target="_blank" class="btn btn-success btn-lg w-100 py-3 fw-bold shadow-sm">
                        <i class="bi bi-whatsapp"></i> Fazer Pedido via WhatsApp
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg w-100 py-3" disabled>
                        Esta peça já foi vendida
                    </button>
                }
            </div>
        </div>
    </div>
</div>