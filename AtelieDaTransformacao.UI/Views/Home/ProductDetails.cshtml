@model AtelieDaTransformacao.Application.DTOs.ProductDto

@{
    ViewData["Title"] = Model.Title;
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-dark">Vitrine</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-6">
            <div class="bg-light rounded-4 overflow-hidden shadow-sm text-center p-3">
                <img src="@Model.ImageUrl" class="img-fluid rounded-3 details-img" alt="@Model.Title">
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-center">
            <span class="badge bg-secondary text-white align-self-start mb-2 px-3 py-2 rounded-pill">
                @Model.CategoryName
            </span>
            <h1 class="display-5 fw-bold text-dark mb-2">@Model.Title</h1>
            <p class="text-muted fs-5 mb-4">Anunciado por <strong class="text-dark">@Model.SellerName</strong></p>
            
            <h2 class="text-success display-6 fw-bold mb-4">R$ @Model.Price.ToString("N2")</h2>
            
            <div class="mb-5">
                <h5 class="fw-bold text-dark">História da peça / Descrição</h5>
                <p class="text-muted lh-base">@Model.Description</p>
            </div>

            <button class="btn btn-success btn-lg w-100 rounded-pill py-3 fw-bold d-flex align-items-center justify-content-center gap-2 whatsapp-btn"
                    data-url="@Model.WhatsAppUrl">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-whatsapp" viewBox="0 0 16 16">
                    <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.69-4.646c-.202-.101-1.194-.588-1.379-.656-.185-.069-.32-.102-.455.101-.135.203-.523.656-.642.793-.119.135-.239.152-.44.051-1.12-.563-1.943-1.039-2.716-2.356-.192-.33.192-.306.55-.101.319.183.45.242.548.332.097.09.135.153.078.256-.057.103-.255.454-.313.518-.058.064-.117.073-.319.03-.202-.043-.85-.314-1.618-.999-.597-.533-1-.18-1.17-.3-.17-.119-.315-.276-.05-.518.242-.224.254-.3.407-.403.153-.102.077-.153-.039-.332-.115-.179-.455-1.102-.624-1.51-.165-.398-.332-.344-.455-.35-.118-.005-.254-.006-.39-.006a.79.79 0 0 0-.572.266C4.242 3.5 3.51 4.218 3.51 5.66c0 1.442 1.05 2.836 1.195 3.031.145.196 2.067 3.16 5.006 4.426.698.301 1.243.48 1.667.615.7.223 1.338.192 1.843.118.563-.083 1.194-.488 1.364-1.026.17-.539.17-1.002.119-1.103-.05-.102-.185-.162-.387-.263 text-white" />
                    Falar com o Artesão
                </button>
            </div>
        </div>
    </div>