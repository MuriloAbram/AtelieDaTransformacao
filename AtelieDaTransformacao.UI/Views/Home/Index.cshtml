@model AtelieDaTransformacao.Application.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Vitrine de Peças";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Ateliê da Transformação</h1>
        <p class="lead text-muted">Peças exclusivas em madeira, tábuas personalizadas e mesas rústicas.</p>
    </div>

    <div class="row mb-4">
        <div class="col-12 text-center">
            <a href="@Url.Action("Index", "Home")"
                   class="btn @(Model.SelectedCategoryId == null ? "btn-dark" : "btn-outline-dark") me-2 mb-2">
                Todos os Produtos
            </a>
            @foreach (var category in Model.Categories)
            {
                <a href="@Url.Action("Index", "Home", new { categoryId = category.Id })"
                       class="btn @(Model.SelectedCategoryId == category.Id ? "btn-dark" : "btn-outline-dark") me-2 mb-2">
                    @category.Name
                </a>
            }
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@(string.IsNullOrEmpty(product.Image) ? "/images/placeholder.jpg" : product.Image)"
                         class="card-img-top object-fit-cover" style="height: 250px;" alt="@product.Title">
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@product.Title</h5>
                        <p class="card-text text-muted text-truncate">@product.Description</p>
                        <h4 class="text-success mt-auto">@product.Price.ToString("C")</h4>
                        
                        <div class="d-grid gap-2 mt-3">
                            <a href="@Url.Action("ProductDetails", "Home", new { id = product.Id })" class="btn btn-outline-secondary">
                                Ver Detalhes
                            </a>
                            
                            @if (product.IsAvailable)
                            {
                                <a href="@product.WhatsAppLink" target="_blank" class="btn btn-success">
                                    <i class="bi bi-whatsapp"></i> Negociar no WhatsApp
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary" disabled>Esgotado / Vendido</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>