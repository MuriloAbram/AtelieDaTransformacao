@model IEnumerable<AtelieDaTransformacao.Application.DTOs.ProductDto>

@{
    ViewData["Title"] = "Vitrine de Artesanatos";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-dark">Ateliê da Transformacao</h1>
        <p class="lead text-muted">Encontre peças exclusivas feitas com amor e conecte-se direto com quem faz.</p>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 product-card shadow-sm border-0">
                    <div class="position-relative">
                        <img src="@product.ImageUrl" class="card-img-top product-img" alt="@product.Title" fallback-img>
                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill">
                            @product.CategoryName
                        </span>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-dark fw-bold text-truncate">@product.Title</h5>
                        <p class="card-text text-muted small text-clamp mb-3">@product.Description</p>
                        
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fs-5 fw-bold text-success">R$ @product.Price.ToString("N2")</span>
                                <span class="text-muted small">Por: @product.SellerName</span>
                            </div>
                            
                            <a asp-action="ProductDetails" asp-route-id="@product.Id" class="btn btn-outline-dark w-100 rounded-pill fw-semibold">
                                Ver Detalhes
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>