@model AtelieDaTransformacao.Application.ViewModels.ProductFormViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Editar Peça";
}

<div class="container-fluid px-0" style="max-width: 850px;">
    <div class="card border-0 shadow-sm p-4 p-md-5 rounded-4 bg-white">
        <div class="mb-4">
            <h3 class="fw-bold text-dark mb-1">Atualizar Especificações</h3>
            <p class="text-muted small">Modifique as propriedades estruturais ou o valor comercial da obra.</p>
        </div>

        <form asp-action="EditProduct" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

            <div class="mb-4">
                <label asp-for="Title" class="form-label fw-semibold text-secondary small text-uppercase">Título do Produto</label>
                <input asp-for="Title" class="form-control form-control-lg fs-6 rounded-3" required />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-secondary small text-uppercase">Preço Ajustado (€)</label>
                    <input name="Price" type="number" step="0.01" class="form-control form-control-lg fs-6 rounded-3" value="@ViewBag.CurrentPrice" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold text-secondary small text-uppercase">Alterar Categoria</label>
                    <select asp-for="CategoryId" class="form-select form-select-lg fs-6 rounded-3" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))" required>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="CoverImageUrl" class="form-label fw-semibold text-secondary small text-uppercase">URL da Imagem</label>
                <input asp-for="CoverImageUrl" class="form-control rounded-3" required />
                <span asp-validation-for="CoverImageUrl" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold text-secondary small text-uppercase">Descrição Detalhada</label>
                <textarea asp-for="Description" class="form-control rounded-3" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="StockQuantity" class="form-label fw-semibold text-secondary small text-uppercase">Atualizar Quantidade em Estoque</label>
                <input asp-for="StockQuantity" type="number" min="0" class="form-control rounded-3" required />
                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
            </div>

            <div class="p-3 bg-light rounded-4 mb-5">
                <div class="form-check form-switch mb-2">
                    <input name="IsAvailable" class="form-check-input" type="checkbox" id="checkAvail" value="true" @(ViewBag.CurrentAvailable == true ? "checked" : "") />
                    <label class="form-check-label fw-medium text-dark small" for="checkAvail">Manter visível e disponível para compra</label>
                </div>
                <div class="form-check form-switch">
                    <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="checkFeat" />
                    <label asp-for="IsFeatured" class="form-check-label fw-medium text-dark small" for="checkFeat">Fixar em destaque na página principal</label>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end pt-3 border-top">
                <a href="@Url.Action("Index", "Admin")" class="btn btn-light rounded-pill px-4">Cancelar</a>
                <button type="submit" class="btn btn-dark rounded-pill px-5 fw-semibold shadow-sm">Salvar Alterações</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}