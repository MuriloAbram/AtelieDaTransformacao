@model AtelieDaTransformacao.Application.DTOs.CreateProductCategoryDto
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nova Categoria";
}

<div class="container-fluid px-0" style="max-width: 600px;">
    <div class="card border-0 shadow-sm p-4 p-md-5 rounded-4 bg-white">
        <div class="mb-4">
            <h3 class="fw-bold text-dark mb-1 serif-title">Nova Categoria de Arte</h3>
            <p class="text-muted small">Crie um novo segmento para organizar as obras e peças do Ateliê.</p>
        </div>

        <form asp-action="CreateCategory" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

            <div class="mb-4">
                <label asp-for="Name" class="form-label fw-semibold text-secondary small text-uppercase">Nome da Categoria</label>
                <input asp-for="Name" class="form-control form-control-lg fs-6 rounded-3" placeholder="Ex: Tábuas de Corte, Mesas Resinadas..." required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-3 justify-content-end pt-3 border-top">
                <a href="@Url.Action("Index", "Admin")" class="btn btn-light rounded-pill px-4">Cancelar</a>
                <button type="submit" class="btn btn-artisan rounded-pill px-5 fw-semibold shadow-sm">Salvar Categoria</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}