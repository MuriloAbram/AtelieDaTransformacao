@model IEnumerable<AtelieDaTransformacao.Application.DTOs.ProductDto>

@{
    ViewData["Title"] = "Gestão do Catálogo";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Gestão de Peças e Produtos</h2>
        <a href="@Url.Action("CreateProduct", "Admin")" class="btn btn-darkfw-bold">+ Adicionar Produto</a>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm p-3">
        <table class="table table-hover align-middle m-0">
            <thead class="table-light">
                <tr>
                    <th>Imagem</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Preço</th>
                    <th>Status</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            <img src="@(string.IsNullOrEmpty(product.Image) ? "/images/placeholder.jpg" : product.Image)"
                                 class="rounded" style="width: 50px; height: 50px; object-fit: cover;" alt="">
                        </td>
                        <td class="fw-bold">@product.Title</td>
                        <td>@product.CategoryName</td>
                        <td class="text-success fw-bold">@product.Price.ToString("C")</td>
                        <td>
                            <span class="badge @(product.IsAvailable ? "bg-success" : "bg-secondary")">
                                @(product.IsAvailable ? "Disponível" : "Esgotado")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a href="@Url.Action("EditProduct", "Admin", new { id = product.Id })" class="btn btn-sm btn-outline-primary">Editar</a>
                                
                                <form asp-action="DeleteProduct" asp-route-id="@product.Id" method="post" onsubmit="return confirm('Tem a certeza que deseja eliminar este produto?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>