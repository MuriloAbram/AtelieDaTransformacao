@model AtelieDaTransformacao.Application.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Painel de Controlo - Ateliê da Transformação";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <div>
            <h1 class="fw-bold text-dark mb-1">🪡 Painel do Ateliê</h1>
            <p class="text-muted mb-0">Faça a gestão dos seus produtos, categorias e destaques da loja.</p>
        </div>
        <div>
            <button class="btn btn-outline-dark me-2 rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNovaCategoria">
                <i class="bi bi-folder-plus me-1"></i> Nova Categoria
            </button>
            <button class="btn btn-dark rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNovoProduto">
                <i class="bi bi-plus-lg me-1"></i> Novo Produto
            </button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 bg-light shadow-sm p-3 rounded-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold small">Total de Produtos</h6>
                        <h2 class="fw-black mb-0">@Model.TotalProdutos</h2>
                    </div>
                    <div class="bg-white p-3 rounded-circle text-success shadow-sm">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 bg-light shadow-sm p-3 rounded-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold small">Categorias Ativas</h6>
                        <h2 class="fw-black mb-0">@Model.Categorias.Count()</h2>
                    </div>
                    <div class="bg-white p-3 rounded-circle text-primary shadow-sm">
                        <i class="bi bi-tags fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 bg-light shadow-sm p-3 rounded-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold small">Peças em Destaque</h6>
                        <h2 class="fw-black mb-0">@Model.ProdutosDestaque</h2>
                    </div>
                    <div class="bg-white p-3 rounded-circle text-warning shadow-sm">
                        <i class="bi bi-star-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs border-0 mb-4" id="adminTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold border-0 bg-transparent text-dark px-4 py-2 border-bottom-dark" id="produtos-tab" data-bs-toggle="tab" data-bs-target="#produtos" type="button" role="tab">🗂️ Gerir Produtos</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold border-0 bg-transparent text-muted px-4 py-2" id="categorias-tab" data-bs-toggle="tab" data-bs-target="#categorias" type="button" role="tab">🏷️ Gerir Categorias</button>
        </li>
    </ul>

    <div class="tab-content bg-white p-4 shadow-sm rounded-4" id="adminTabsContent">
        <div class="tab-pane fade show active" id="produtos" role="tabpanel">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Imagem</th>
                            <th>Produto</th>
                            <th>Categoria</th>
                            <th>Preço</th>
                            <th>Status</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prod in Model.Produtos)
                        {
                            <tr>
                                <td>
                                    <img src="@prod.Image" class="rounded-3 shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.src='/images/placeholder.jpg';" />
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@prod.Title</div>
                                    <small class="text-muted text-truncate d-inline-block" style="max-width: 200px;">@prod.Description</small>
                                </td>
                                <td><span class="badge bg-light text-dark px-3 py-2 rounded-pill border">@prod.CategoryName</span></td>
                                <td class="fw-bold text-success">@prod.Price.ToString("C")</td>
                                <td>
                                    @if (prod.IsAvailable) { <span class="badge bg-success-subtle text-success px-2 py-1 rounded">Disponível</span> }
                                    else { <span class="badge bg-danger-subtle text-danger px-2 py-1 rounded">Esgotado</span> }
                                    
                                    @if (prod.IsFeatured) { <span class="badge bg-warning-subtle text-warning ms-1 px-2 py-1 rounded">⭐ Destaque</span> }
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditProduct" asp-route-id="@prod.Id" class="btn btn-sm btn-light border rounded-circle p-2 me-1 text-primary"><i class="bi bi-pencil-square"></i></a>
                                    <a asp-action="DeleteProduct" asp-route-id="@prod.Id" class="btn btn-sm btn-light border rounded-circle p-2 text-danger" onclick="return confirm('Apagar este artesanato?');"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab-pane fade" id="categorias" role="tabpanel">
            <div class="table-responsive" style="max-width: 600px;">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nome da Categoria</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
    @if (Model != null && Model.Categorias != null && Model.Categorias.Any())
    {
        @foreach (var cat in Model.Categorias)
        {
            <tr>
                <td class="fw-bold text-dark">@cat.Name</td>
                <td class="text-end">
                    <a asp-action="DeleteCategory" asp-route-id="@cat.Id" class="btn btn-sm btn-light border rounded-circle p-2 text-danger" onclick="return confirm('Remover categoria?');">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        }
    }
    else
    {
        <tr>
            <td colspan="2" class="text-muted text-center py-4">
                <i class="bi bi-tag d-block fs-3 mb-2"></i>
                Nenhuma categoria cadastrada ainda.
            </td>
        </tr>
    }
</tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNovaCategoria" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white rounded-top-4">
                <h5 class="modal-title fw-bold">🏷️ Adicionar Nova Categoria</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateCategory" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Nome da Categoria de Artesanato</label>
                        <input type="text" name="Name" class="form-control rounded-3 p-2" placeholder="Ex: Crochê, Madeira, Cerâmica, Velas..." required />
                        <div class="form-text text-muted">Use nomes claros e intuitivos para os seus clientes.</div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-dark rounded-pill px-4">Salvar Categoria</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body { background-color: #fcfbf7; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .nav-tabs .nav-link.active { border-bottom: 3px solid #212529 !important; color: #212529 !important; }
    .card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .card:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08)!important; }
    .fw-black { font-weight: 800; }
</style>