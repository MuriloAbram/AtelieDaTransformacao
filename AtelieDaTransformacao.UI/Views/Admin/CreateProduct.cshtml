@model AtelieDaTransformacao.Application.ViewModels.ProductFormViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nova Peça";
}

<div class="container-fluid px-0" style="max-width: 850px;">
    <div class="card border-0 shadow-sm p-4 p-md-5 rounded-4 bg-white">
        <div class="mb-4">
            <h3 class="fw-bold text-dark mb-1 serif-title">Cadastrar Nova Obra</h3>
            <p class="text-muted small">Alimente a vitrina pública com produtos exclusivos do Ateliê.</p>
        </div>

        <form asp-action="CreateProduct" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

            <div class="mb-4">
                <label asp-for="Title" class="form-label fw-semibold text-secondary small text-uppercase">Título Comercial</label>
                <input asp-for="Title" class="form-control form-control-lg fs-6 rounded-3" placeholder="Ex: Tábua Artisan em Imbuia Maciça" required />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label asp-for="Price" class="form-label fw-semibold text-secondary small text-uppercase">Preço de Venda (€)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg fs-6 rounded-3" placeholder="0,00" required />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold text-secondary small text-uppercase">Categoria da Peça</label>
                    <select asp-for="CategoryId" class="form-select form-select-lg fs-6 rounded-3" asp-items="@(new SelectList(Model.Categories, "Id", "Name"))" required>
                        <option value="">Selecione uma categoria...</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="CoverImageUrl" class="form-label fw-semibold text-secondary small text-uppercase">URL da Imagem de Cobertura</label>
                <input asp-for="CoverImageUrl" class="form-control rounded-3" placeholder="https://exemplo.com/imagem.jpg" required />
                <span asp-validation-for="CoverImageUrl" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold text-secondary small text-uppercase">Descrição e Detalhes Técnicos</label>
                <textarea asp-for="Description" class="form-control rounded-3" rows="4" placeholder="Detalhes sobre veios da madeira, acabamento em óleo mineral, resina..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label asp-for="ReleaseYear" class="form-label fw-semibold text-secondary small text-uppercase">Ano de Fabricação</label>
                    <input asp-for="ReleaseYear" type="number" class="form-control rounded-3" required />
                    <span asp-validation-for="ReleaseYear" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="StockQuantity" class="form-label fw-semibold text-secondary small text-uppercase">Quantidade em Estoque</label>
                    <input asp-for="StockQuantity" type="number" min="0" class="form-control rounded-3" placeholder="Ex: 5" required />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>
            </div>

            <div class="p-3 rounded-4 mb-5" style="background-color: #f8f9fa;">
                <div class="form-check form-switch mb-2">
                    <input asp-for="IsAvailable" class="form-check-input" type="checkbox" id="checkAvail" />
                    <label class="form-check-label fw-medium text-dark small" for="checkAvail">Disponível para venda imediata</label>
                </div>
                <div class="form-check form-switch">
                    <input asp-for="IsFeatured" class="form-check-input" type="checkbox" id="checkFeat" />
                    <label class="form-check-label fw-medium text-dark small" for="checkFeat">Destacar este item na página principal</label>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end pt-3 border-top">
                <a href="@Url.Action("Index", "Admin")" class="btn btn-light rounded-pill px-4">Cancelar</a>
                <button type="submit" class="btn btn-dark rounded-pill px-5 fw-semibold shadow-sm">Publicar Arte</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}