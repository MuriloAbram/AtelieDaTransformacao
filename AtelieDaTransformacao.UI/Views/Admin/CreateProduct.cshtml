@model AtelieDaTransformacao.Application.DTOs.ProductDto

@{
    ViewData["Title"] = "Novo Produto";
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0 p-4">
        <h2 class="fw-bold mb-4">Registar Nova Peça em Madeira</h2>
        
        <form asp-action="CreateProduct" method="post">
            <div class="mb-3">
                <label asp-for="Title" class="form-label">Nome do Produto</label>
                <input asp-for="Title" class="form-control" placeholder="Ex: Tábua de Churrasco Rústica" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Price" class="form-label">Preço (€)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label">Categoria</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                        <option value="">Selecione...</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Image" class="form-label">URL da Imagem</label>
                <input asp-for="Image" class="form-control" placeholder="https://linkdaimagem.com/foto.jpg" />
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descrição da Peça</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check form-switch">
                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                <label asp-for="IsAvailable" class="form-check-label">Disponível para venda imediata</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4 fw-bold">Gravar Peça</button>
                <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>