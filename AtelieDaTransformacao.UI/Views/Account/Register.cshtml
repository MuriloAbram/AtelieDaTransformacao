@model AtelieDaTransformacao.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Criar Perfil";
}

<div class="container py-5">
    <div class="row justify-content-center mx-0">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-4">
            <div class="card border-0 shadow-sm p-4 p-md-5 bg-white rounded-4 border-top border-4 border-dark">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark serif-title">Registrar-Se</h3>
                    <p class="text-muted small">Registre um perfil de acesso para operações de estoque</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" type="email" class="form-control" placeholder="nome@provedor.com" required />
                        <label asp-for="Email"><i class="bi bi-envelope me-2 text-muted"></i>Endereço de E-mail</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Senha" required />
                        <label asp-for="Password"><i class="bi bi-lock me-2 text-muted"></i>Defina a Senha</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirmar" required />
                        <label asp-for="ConfirmPassword"><i class="bi bi-shield-check me-2 text-muted"></i>Confirme a Senha</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-artisan w-100 py-3 rounded-3 shadow-sm text-uppercase font-monospace tracking-wider small mb-3">
                        Efetuar Cadastro
                    </button>

                    <div class="text-center">
                        <span class="small text-muted">Já é registrado? <a asp-action="Login" class="text-decoration-none fw-semibold" style="color: var(--artisan-clay)">Fazer Login</a></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>