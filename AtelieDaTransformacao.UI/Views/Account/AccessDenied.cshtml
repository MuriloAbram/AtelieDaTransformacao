@{
    ViewData["Title"] = "Bloqueado";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center mx-0">
        <div class="col-12 col-md-6 text-center">
            <div class="d-inline-flex p-4 rounded-circle mb-4" style="background-color: rgba(184, 93, 67, 0.1); color: var(--artisan-clay)">
                <i class="bi bi-shield-lock-fill fs-1"></i>
            </div>
            <h1 class="display-6 fw-bold text-dark serif-title mb-2">Restrição de Operação</h1>
            <p class="text-muted fs-6 mb-5 col-lg-10 mx-auto">Sua identidade atual não está associada ao grupo de administradores da oficina de transformação.</p>
            
            <div class="d-flex gap-2 justify-content-center">
                <a href="@Url.Action("Index", "Home")" class="btn btn-artisan rounded-pill px-4 py-2">
                    <i class="bi bi-arrow-left me-2"></i>Voltar para Vitrina
                </a>
            </div>
        </div>
    </div>
</div>