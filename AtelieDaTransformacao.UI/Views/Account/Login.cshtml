@model AtelieDaTransformacao.Application.DTOs.LoginDto
@{
    ViewData["Title"] = "Entrar";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center mx-0">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">
            <div class="card border-0 shadow-sm p-4 p-md-5 bg-white rounded-4 border-top border-4 border-dark">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark serif-title">Login</h3>
                    <p class="text-muted small">Gerencie as suas peças e configurações do catálogo</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" type="email" class="form-control" placeholder="nome@provedor.com" required />
                        <label asp-for="Email"><i class="bi bi-envelope me-2 text-muted"></i>E-mail corporativo</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Palavra-passe" required />
                        <label asp-for="Password"><i class="bi bi-key me-2 text-muted"></i>Sua Palavra-passe</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-artisan w-100 py-3 rounded-3 shadow-sm text-uppercase font-monospace tracking-wider small mb-3">
                        Autenticar Entrada
                    </button>

                    <div class="text-center">
                        <span class="small text-muted">Novo no comitê? <a asp-action="Register" class="text-decoration-none fw-semibold" style="color: var(--artisan-clay)">Criar uma credencial</a></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>